<article class="recipe-card" data-category="{{ recipe.data.category }}" data-tags="{{ (recipe.data.tags or []) | join(',') }}">
  <a class="recipe-card__image" href="{{ recipe.url | url }}">
    <img src="{{ recipe.data.cover | imageFor }}" alt="" loading="lazy" decoding="async">
  </a>
  <div class="recipe-card__body">
    <div class="meta-row">
      <span class="pill">{{ recipe.data.category | categoryLabel }}</span>
      {% if recipe.data.difficulty %}<span>{{ recipe.data.difficulty }}</span>{% endif %}
      {% if recipe.data.totalTime %}<span>{{ recipe.data.totalTime }}</span>{% endif %}
    </div>
    <h3><a href="{{ recipe.url | url }}">{{ recipe.data.title }}</a></h3>
    {% if recipe.data.summary %}<p>{{ recipe.data.summary }}</p>{% endif %}
    {% if recipe.data.tags %}
      <div class="tag-row">
        {% for tag in recipe.data.tags %}
          {% if loop.index <= 3 %}<a href="{{ ('/' if recipe.data.lang == 'ta' else '/' + recipe.data.lang + '/') | url }}tags/{{ tag | urlencode }}/">#{{ tag }}</a>{% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</article>
