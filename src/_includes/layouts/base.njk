{% set currentLang = langItem.code if langItem else (lang or pageLang or "ta") %}
{% set language = languages | languageMeta(currentLang) %}
{% set labels = ui[currentLang] or ui.en %}
{% set currentTranslationId = translationId or page.fileSlug %}
{% set pageTitle = (title + " | " + site.name) if title else site.name %}
{% set pageDescription = summary or description or site.description %}
{% set pageImage = socialImage or site.socialImage %}
{% if isRecipePage and cover %}{% set pageImage = socialImage or (cover | socialImageFor) %}{% endif %}
{% set pageImageUrl = pageImage | absoluteUrl(site) %}
{% set pageUrl = page.url | absoluteUrl(site) %}
<!doctype html>
<html lang="{{ currentLang }}" data-theme="system">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}">
    <link rel="canonical" href="{{ pageUrl }}">
    {% for item in languages %}
      {% if translationId and collections.recipes %}
        {% set translated = collections.recipes | translationFor(translationId, item.code) %}
        {% if translated %}<link rel="alternate" hreflang="{{ item.code }}" href="{{ translated.url | absoluteUrl(site) }}">{% endif %}
      {% else %}
        <link rel="alternate" hreflang="{{ item.code }}" href="{{ item.home | absoluteUrl(site) }}">
      {% endif %}
    {% endfor %}
    <meta property="og:type" content="{{ 'article' if isRecipePage else 'website' }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="{{ 'ta_IN' if currentLang == 'ta' else 'en_US' }}">
    {% for item in languages %}
      {% if item.code != currentLang %}<meta property="og:locale:alternate" content="{{ 'ta_IN' if item.code == 'ta' else 'en_US' }}">{% endif %}
    {% endfor %}
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:image" content="{{ pageImageUrl }}">
    <meta property="og:image:secure_url" content="{{ pageImageUrl }}">
    <meta property="og:image:type" content="{{ pageImage | imageMimeType }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ title or site.name }}">
    {% if isRecipePage and published %}<meta property="article:published_time" content="{{ published | dateIso }}">{% endif %}
    {% if isRecipePage and updated %}<meta property="article:modified_time" content="{{ updated | dateIso }}">{% endif %}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ pageTitle }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ pageImageUrl }}">
    <meta name="twitter:image:alt" content="{{ title or site.name }}">
    <link rel="icon" href="{{ '/favicon.ico' | url }}" sizes="any">
    <link rel="apple-touch-icon" href="{{ '/assets/images/recipe-atlas.png' | url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0&family=Noto+Sans+Tamil:wght@400;500;700;800&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
    <script>
      (() => {
        const saved = localStorage.getItem("recipeatlas.theme") || "system";
        document.documentElement.dataset.theme = saved;
      })();
    </script>
    <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
  </head>
  <body data-site-root="{{ '/' | url }}">
    <a class="skip-link" href="#main">{{ labels.skipToContent }}</a>
    <header class="site-header">
      <a class="brand" href="{{ language.home | url }}" aria-label="{{ site.name }} home">
        <span class="brand-mark"><img src="{{ '/assets/images/recipe-atlas.png' | url }}" alt="" width="36" height="36"></span>
        <span class="brand-copy">
          <span class="brand-name">{{ site.name }}</span>
          <span class="brand-tagline">Bangalore Samayal</span>
        </span>
      </a>
      <button class="icon-button mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        <span class="material-symbols-rounded" aria-hidden="true">menu</span>
        <span class="sr-only">{{ labels.menu }}</span>
      </button>
      <nav id="site-nav" class="site-nav" aria-label="Primary">
        <a href="{{ language.home | url }}" {% if page.url == language.home %}aria-current="page"{% endif %}>{{ labels.home }}</a>
        <a href="{{ language.recipes | url }}" {% if page.url == language.recipes %}aria-current="page"{% endif %}>{{ labels.recipes }}</a>
        <a href="{{ language.tags | url }}" {% if page.url == language.tags %}aria-current="page"{% endif %}>{{ labels.tags }}</a>
        <a href="{{ language.about | url }}" {% if page.url == language.about %}aria-current="page"{% endif %}>{{ labels.about }}</a>
        <a href="{{ language.search | url }}" {% if page.url == language.search %}aria-current="page"{% endif %}>{{ labels.search }}</a>
      </nav>
      <div class="header-actions">
        <label class="select-shell">
          <span class="sr-only">{{ labels.language }}</span>
          <select data-language-switch>
            {% for item in languages %}
              {% if isRecipePage and collections.recipes %}
                {% set translated = collections.recipes | translationFor(currentTranslationId, item.code) %}
                <option value="{{ (translated.url if translated else page.url) | url }}" data-lang="{{ item.code }}" data-unavailable="{{ 'false' if translated else 'true' }}" {% if item.code == currentLang %}selected{% endif %}>{{ item.name }}</option>
              {% else %}
                {% set fallbackPage = page.url | localizedUrl(currentLang, item.code) %}
                <option value="{{ fallbackPage | url }}" data-lang="{{ item.code }}" {% if item.code == currentLang %}selected{% endif %}>{{ item.name }}</option>
              {% endif %}
            {% endfor %}
          </select>
        </label>
        <label class="select-shell">
          <span class="sr-only">{{ labels.theme }}</span>
          <select data-theme-switch>
            <option value="system">{{ labels.system }}</option>
            <option value="light">{{ labels.light }}</option>
            <option value="dark">{{ labels.dark }}</option>
          </select>
        </label>
      </div>
    </header>

    <main id="main">
      <div class="translation-toast" data-translation-toast hidden></div>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <span class="footer-mark"><img src="{{ '/assets/images/recipe-atlas.png' | url }}" alt="" width="40" height="40"></span>
        <span>
          <strong>{{ site.name }}</strong>
          <span>Bangalore Samayal</span>
        </span>
      </div>
      <p class="footer-copy">&copy; <span data-copyright-year data-start-year="2026">2026</span> {{ site.name }}. All rights reserved.</p>
      <nav class="footer-links" aria-label="{{ labels.footer }}">
        <a href="{{ '/feed.xml' | url }}" target="_blank" rel="noopener">RSS</a>
        <a href="{{ '/sitemap.xml' | url }}" target="_blank" rel="noopener">Sitemap</a>
      </nav>
    </footer>
    <button class="back-to-top icon-button" type="button" data-back-to-top aria-label="{{ labels.backToTop }}">
      <span class="material-symbols-rounded" aria-hidden="true">keyboard_arrow_up</span>
    </button>
    <script src="{{ '/assets/js/main.js' | url }}" defer></script>
    {% if loadSearch %}<script src="{{ '/assets/js/search.js' | url }}" defer></script>{% endif %}
    {% if content | hasMermaid %}<script type="module" src="{{ '/assets/js/mermaid-loader.js' | url }}"></script>{% endif %}
  </body>
</html>
