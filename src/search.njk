---
layout: layouts/base.njk
pagination:
  data: languages
  size: 1
  alias: langItem
permalink: "{{ langItem.search }}"
lang: "{{ langItem.code }}"
title: Search
loadSearch: true
---
{% set labels = ui[langItem.code] or ui.en %}
<section class="search-app" data-search-app data-lang="{{ langItem.code }}" data-label-veg="{{ labels.veg }}" data-label-non-veg="{{ labels.nonVeg }}" data-label-no-results="{{ labels.noRecipesFound }}" data-label-search-unavailable="{{ labels.searchIndexUnavailable }}">
  <div class="section-heading">
    <p class="eyebrow">{{ langItem.name }}</p>
    <h1>{{ labels.search }}</h1>
  </div>
  <form class="search-controls" role="search" data-search-form>
    <label>
      <span class="sr-only">{{ labels.searchRecipes }}</span>
      <input type="search" name="q" placeholder="{{ 'பெயர், பொருள், குறிச்சொல் - / அழுத்தவும்' if langItem.code == 'ta' else 'Title, ingredient, tag - press /' }}" data-search-input autocomplete="off">
    </label>
    <select data-search-category aria-label="{{ labels.category }}">
      <option value="all">{{ labels.all }}</option>
      <option value="veg">{{ labels.veg }}</option>
      <option value="non-veg">{{ labels.nonVeg }}</option>
    </select>
    <select data-search-language aria-label="{{ labels.language }}">
      <option value="{{ langItem.code }}">{{ langItem.name }}</option>
      <option value="all">{{ labels.allLanguages }}</option>
      {% for item in languages %}
        {% if item.code != langItem.code %}<option value="{{ item.code }}">{{ item.name }}</option>{% endif %}
      {% endfor %}
    </select>
  </form>
  <div class="search-results" data-search-results role="list" aria-live="polite"></div>
</section>
