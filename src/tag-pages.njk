---
layout: layouts/base.njk
pagination:
  data: collections.recipeTagPages
  size: 1
  alias: tagPage
permalink: "{{ tagPage.permalink }}"
lang: "{{ tagPage.lang }}"
title: "Tag"
---
{% set language = languages | languageMeta(tagPage.lang) %}
{% set taggedRecipes = collections.recipes | recipesByTag(tagPage.lang, tagPage.tag) %}
<section class="page-shell">
  <div class="section-heading">
    <p class="eyebrow">{{ language.name }}</p>
    <h1>#{{ tagPage.tag }}</h1>
    <p>{{ tagPage.count }} recipes</p>
  </div>
  <div class="card-grid">
    {% for recipe in taggedRecipes %}
      {% include "components/recipe-card.njk" %}
    {% endfor %}
  </div>
</section>
